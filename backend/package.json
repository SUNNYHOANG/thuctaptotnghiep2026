{
  "name": "student-activity-management-backend",
  "version": "1.0.0",
  "description": "Backend API cho hệ thống quản lý công tác sinh viên và điểm rèn luyện",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --testPathPatterns=tests/ --forceExit",
    "test:run": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --testPathPatterns=tests/ --forceExit --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "cross-env": "^10.1.0",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2"
  }
}
